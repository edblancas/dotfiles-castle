#!/usr/bin/env bash
# Claude Code notification handler
# - Sends Ghostty native notification via OSC 777 (tmux DCS passthrough)
# - Rings tmux bell to show bell icon (󰂞) in window tab

INPUT=$(cat)
MESSAGE=$(printf '%s' "$INPUT" | python3 -c "
import sys, json
try:
    d = json.load(sys.stdin)
    print(d.get('message', 'Task complete'))
except:
    print('Task complete')
" 2>/dev/null)

TTY=$(tmux display-message -p '#{pane_tty}' 2>/dev/null)
TTY="${TTY:-/dev/tty}"

{
    if [ -n "$TMUX" ]; then
        printf '\033Ptmux;\033\033]777;notify;Claude Code;%s\007\033\\' "$MESSAGE"
    else
        printf '\033]777;notify;Claude Code;%s\007' "$MESSAGE"
    fi
    printf '\a'
} > "$TTY"

exit 0
