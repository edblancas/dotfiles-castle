#!/usr/bin/env bash
# Claude Code notification handler
# - Sends macOS notification via terminal-notifier
#   title:    Claude Code
#   subtitle: folder where Claude was invoked
#   body:     notification message
#   click:    focuses Ghostty and switches to the tmux pane where Claude is running
# - Rings tmux bell to show bell icon (󰂞) in window tab

INPUT=$(cat)
MESSAGE=$(printf '%s' "$INPUT" | python3 -c "
import sys, json
try:
    d = json.load(sys.stdin)
    print(d.get('message', 'Task complete'))
except:
    print('Task complete')
" 2>/dev/null)

FOLDER=$(basename "$PWD")
SOCKET=$(printf '%s' "$TMUX" | cut -d, -f1)
PANE="$TMUX_PANE"

terminal-notifier \
    -title "Claude Code" \
    -subtitle "$FOLDER" \
    -message "$MESSAGE" \
    -sound "Funk" \
    -activate "com.mitchellh.ghostty" \
    -execute "/opt/homebrew/bin/tmux -S '$SOCKET' switch-client -t '$PANE'" &

printf '\a' > /dev/tty

exit 0
